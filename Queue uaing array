#include<stdio.h>
#include<stdlib.h>
int queue[100],n,i,j,front=-1,rear=-1,x,ch;
void insert();
void delet();
void display();
int main()
{
	printf("enter queue size");
	scanf("%d",&n);
	printf("\nQueue operations are 1.Insert,2.Delete,3.Display,4.Exit\n");
	while(1)
	{
		printf("\nenter your choice\n");
		scanf("%d",&ch);
		switch(ch)
		{
			case 1:  insert();    break;
			case 2:  delet();     break;
			case 3:  display();   break;
			case 4:  exit(0);     break;
			default:  printf("\nInvalid choice");
		}
	}
	return 0;
}
void insert()
{
	if(rear==n-1)
	printf("\nqueue is full");
	else
	{
		rear++;
		printf("\nenter queue element");
		scanf("%d",&x);
		queue[rear]=x;
		printf("\nelement inserted\n");
	}
}
void delet()
{
	if(front==rear)
	printf("\nqueue is empty");
	else
	{
		front++;
		printf("\ndeleted element is %d",queue[front]);
	}
}
void display()
{
	if(front==rear)
	{
	printf("\nqueue is empty");
    }
	else
	{
		printf("Queue elements are :\n");
		for(i=front+1;i<=rear;i++)
		{
			printf(" %d",queue[i]);
		}
	}
}
