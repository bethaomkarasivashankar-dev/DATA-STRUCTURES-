#include<stdio.h>
struct address
{
	char street[50];
	char city[50];
	long int pincode;
};
struct student
{
	int rno;
	char name[50];
	float per;
	struct address a;
};
int main()
{
	struct student s={101,"siva",90.9,{"ADB road","KKD",533437}};
	printf("%d %s %.2f %s %s %ld",s.rno,s.name,s.per,s.a.street,s.a.city,s.a.pincode);
	return 0;
}
