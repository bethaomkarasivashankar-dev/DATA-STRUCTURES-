#include<stdio.h>
struct Employee {
    int empId;
    char name[50];
    long long phone;
};

int main() 
{
    int n, i;
    printf("Enter number of employees: ");
    scanf("%d", &n);
    struct Employee e[n];
    for(i = 0; i < n; i++) {
        printf("\nEnter details of employee %d\n", i + 1);
        printf("Employee ID: ");
        scanf("%d", &e[i].empId);
        printf("Name: ");
        scanf(" %[^\n]", e[i].name);
        printf("Phone Number: ");
        scanf("%lld", &e[i].phone);
    }
    printf("\n----- Employee Details -----\n");
    for(i = 0; i < n; i++) {
        printf("\nEmployee %d\n", i + 1);
        printf("Employee ID: %d\n", e[i].empId);
        printf("Name: %s\n", e[i].name);
        printf("Phone Number: %lld\n", e[i].phone);
    }

    return 0;
}
